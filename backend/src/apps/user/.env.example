LOG_LEVEL=INFO
LOG_FORMAT="%(levelname)-10s%(asctime)-25s %(name)s - %(funcName)-15s: %(lineno)-5d - %(message)3s"
LOG_NAME=user

DATABASE_HOST=pg
DATABASE_PORT_NETWORK=5432
DATABASE_USER=admin
DATABASE_PASSWORD=password
DATABASE_NAME=kino-user
DATABASE_DIALECT=postgresql
DATABASE_DRIVER=asyncpg

ECHO=true
ECHO_POOL=false
POOL_SIZE=5
MAX_OVERFLOW=10
POOL_TIMEOUT=30
POOL_RECYCLE=1800
POOL_PRE_PING=true
AUTO_FLUSH=true
EXPIRE_ON_COMMIT=false

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_HOST=broker
RABBITMQ_PORT=5672

STORAGE_BACKEND=local
STORAGE_BUCKET=user
STORAGE_LOCAL_ROOT=storage
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_USE_SSL=true

IMAGE_ALLOWED_MIME_TYPES=["image/jpeg","image/png","image/webp"]
IMAGE_MAX_SIZE_BYTES=10485760

PROJECT_SERVICE_TIMEOUT_SECONDS=10
CONFIRMATION_SECRET_KEY=kino-confirmation-dev-key-please-change
CONFIRMATION_TTL_HOURS=24
PUBLIC_BASE_URL=http://localhost:8000
CONFIRMATION_ALGORITHM=HS256
